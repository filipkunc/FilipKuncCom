---
// Live partial-ligature selection: the ffi glyph rendered two-tone by the
// same pipeline as the editor, in the active theme.
---

<div id="hb-ligature-demo" class="hb-demo">
  <canvas></canvas>
  <p class="hb-loading" hidden>loading wasm + font…</p>
</div>

<style>
  .hb-demo { margin: 1.5rem 0; position: relative; }
  canvas {
    width: 100%; min-height: 80px; border: 1px solid var(--rule, #ccc);
    border-radius: 6px; display: block; background: var(--bg, #fff);
  }
  .hb-loading {
    position: absolute; inset: 0; display: flex; align-items: center;
    justify-content: center; margin: 0; pointer-events: none;
    color: var(--muted, #666); font-size: 0.9rem;
    animation: hb-pulse 1.2s ease-in-out infinite;
  }
  @keyframes hb-pulse { 50% { opacity: 0.4; } }
</style>

<script>
  import { mountWhenVisible } from '../../scripts/hb-editor/src/lazy.mjs';
  import { mountLigatureDemo } from '../../scripts/hb-editor/src/demo-ligature.mjs';
  import garamondUrl from '../../scripts/hb-editor/fonts/EBGaramond-subset.ttf?url';

  const root = document.getElementById('hb-ligature-demo')!;
  const loading = root.querySelector<HTMLElement>('.hb-loading')!;
  mountWhenVisible(root, () => {
    loading.hidden = false;
    mountLigatureDemo(root, { fontUrl: garamondUrl }).then(() => loading.remove());
  });
</script>
