---
// Renders the code-search benchmark from bench-results.json, regenerated by
// `npm run bench:codesearch`. Two tables: what each index costs to build and
// store, and how fast each tool answers the same queries over the Node.js tree.
import data from '../content/posts/code-search/bench-results.json';

type Query = {
  id: string;
  ms?: number;
  matches?: number;
  candidates?: number;
  candidatePct?: number;
  filterMs?: number;
  skipped?: boolean;
};
type Tool = {
  name: string;
  family: 'noindex' | 'ours' | 'index';
  buildMs?: number;
  indexBytes?: number;
  queries: Query[];
  note?: string;
};

const tools = data.tools as Tool[];
const corpus = data.corpus as { files: number; lines: number; bytes: number };

// Short, stable column labels for the queries, in display order.
const QUERY_LABELS: Record<string, string> = {
  MakeCallback: 'MakeCallback',
  uv_async_init: 'uv_async_init',
  napi_create_function: 'napi_create_function',
  'napi-regex': 'napi_create_[a-z]+',
  'common-word': 'function',
};
const queryIds = Object.keys(QUERY_LABELS).filter((id) =>
  tools.some((t) => t.queries.some((q) => q.id === id && !q.skipped)),
);

const ms = (v?: number) => (v == null ? '—' : v >= 100 ? Math.round(v).toLocaleString() : v.toFixed(1));
const mb = (b?: number) => (b == null ? '—' : `${(b / 1e6).toFixed(0)} MB`);
const secs = (m?: number) => (m == null ? '—' : `${(m / 1000).toFixed(1)} s`);
const ratio = (b?: number) => (b == null ? '—' : `${((b / corpus.bytes) * 100).toFixed(0)}%`);

const indexed = tools.filter((t) => t.family !== 'noindex');
const cellFor = (t: Tool, id: string) => t.queries.find((q) => q.id === id);
const fastestForQuery = new Map<string, string>();
for (const id of queryIds) {
  let best = '';
  let bestMs = Infinity;
  for (const t of tools) {
    const c = cellFor(t, id);
    if (c && c.ms != null && c.ms < bestMs) { bestMs = c.ms; best = t.name; }
  }
  fastestForQuery.set(id, best);
}
---

<figure class="csbench">
  <figcaption class="top">
    Indexing the Node.js source tree: <strong>{corpus.files.toLocaleString()}</strong> files,
    {' '}<strong>{(corpus.lines / 1e6).toFixed(1)}M</strong> lines,
    {' '}<strong>{(corpus.bytes / 1e9).toFixed(2)} GB</strong>.
  </figcaption>
  <div class="scroll">
    <table>
      <thead>
        <tr><th>index</th><th class="num">build time</th><th class="num">size on disk</th><th class="num">vs source</th></tr>
      </thead>
      <tbody>
        {indexed.map((t) => (
          <tr>
            <td>{t.name}</td>
            <td class="num">{secs(t.buildMs)}</td>
            <td class="num">{mb(t.indexBytes)}</td>
            <td class="num">{ratio(t.indexBytes)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</figure>

<figure class="csbench">
  <figcaption class="top">Warm query latency, best of 5. The fastest tool per query is emphasised.</figcaption>
  <div class="scroll">
    <table>
      <thead>
        <tr>
          <th>tool</th>
          {queryIds.map((id) => <th class="num mono">{QUERY_LABELS[id]}</th>)}
        </tr>
      </thead>
      <tbody>
        {tools.map((t) => (
          <tr>
            <td>{t.name}{t.family === 'noindex' && <span class="tag">no index</span>}</td>
            {queryIds.map((id) => {
              const c = cellFor(t, id);
              const best = fastestForQuery.get(id) === t.name;
              return (
                <td class:list={['num', { best }]}>
                  {c && c.ms != null ? <>{ms(c.ms)}<span class="unit"> ms</span></> : '—'}
                </td>
              );
            })}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <figcaption>
    On a {data.host.cpu.replace(/\s+/g, ' ').trim()} ({data.host.cores} threads), captured {data.generatedOn}.
    Regenerate with <code>npm run bench:codesearch</code>.
  </figcaption>
</figure>

<style>
  .csbench { margin: 1.75rem 0; }
  .csbench .scroll { overflow-x: auto; }
  .csbench table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  .csbench th, .csbench td { padding: 0.45rem 0.7rem; border-bottom: 1px solid var(--rule); text-align: left; white-space: nowrap; }
  .csbench th.num, .csbench td.num { text-align: right; font-variant-numeric: tabular-nums; font-family: 'JetBrains Mono', ui-monospace, monospace; }
  .csbench th.mono { font-family: 'JetBrains Mono', ui-monospace, monospace; font-weight: 600; font-size: 0.8rem; }
  .csbench thead th { color: var(--muted); font-weight: 600; border-bottom: 2px solid var(--rule); }
  .csbench td.best { color: var(--fg); font-weight: 700; }
  .csbench .unit { color: var(--muted); font-size: 0.85em; }
  .csbench .tag { margin-left: 0.5rem; font-size: 0.7rem; color: var(--muted); border: 1px solid var(--rule); border-radius: 3px; padding: 0.05rem 0.3rem; vertical-align: middle; }
  .csbench figcaption { font-size: 0.82rem; color: var(--muted); }
  .csbench figcaption.top { margin-bottom: 0.6rem; }
  .csbench figcaption:not(.top) { margin-top: 0.6rem; }
  .csbench figcaption code { font-family: 'JetBrains Mono', ui-monospace, monospace; }
</style>
