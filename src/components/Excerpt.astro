---
// Show a region of a real source file (or the whole file) as a code block.
// The code is read at build time, so it is always in sync with what ships.
import { basename } from 'node:path';
import { Code } from 'astro:components';
import CodeFile from './CodeFile.astro';
import { readSource, locateRegion, sourceUrl } from '../lib/snippets';

interface Props {
  source: string;
  region?: string;
  lang: Parameters<typeof Code>[0]['lang'];
  // Override the file label (defaults to the source's basename).
  label?: string;
}

const { source, region, lang, label } = Astro.props;
const full = readSource(source);

const located = region
  ? locateRegion(full, region)
  : { code: full, startLine: 1, endLine: full.split('\n').length };

// When several excerpts come from the same file, the bare filename repeats and
// reads as "the same file again". Append the region so the label is a
// breadcrumb to the part being shown.
const filename = label ?? (region ? `${basename(source)} › ${region}` : basename(source));
const href = sourceUrl(source, located.startLine, located.endLine);
---

<CodeFile code={located.code} lang={lang} filename={filename} href={href} />
