---
// Renders the allocator benchmark from bench-results.json, regenerated by
// `npm run bench:alloc`. Rows are thread counts, columns are the four
// allocators, cells are throughput in millions of operations per second. The
// fastest allocator in each row is emphasised, so the scaling story reads down
// the columns and across the rows.
import data from '../content/posts/cpp-data-races/bench-results.json';

const cell = (impl: string, threads: number) =>
  data.results.find((r) => r.impl === impl && r.threads === threads);

// The best (highest M ops/s) implementation per thread count, for emphasis.
const bestByThreads = new Map<number, string>();
for (const t of data.threadCounts) {
  let best = data.impls[0].key;
  let bestMops = -1;
  for (const i of data.impls) {
    const c = cell(i.key, t);
    if (c && c.mops > bestMops) { bestMops = c.mops; best = i.key; }
  }
  bestByThreads.set(t, best);
}

const fmt = (mops: number) => (mops >= 100 ? Math.round(mops).toLocaleString() : mops.toFixed(1));
---

<figure class="abench">
  <table>
    <thead>
      <tr>
        <th>threads</th>
        {data.impls.map((i) => <th class="num">{i.label}</th>)}
      </tr>
    </thead>
    <tbody>
      {data.threadCounts.map((t) => (
        <tr>
          <td class="threads">{t}</td>
          {data.impls.map((i) => {
            const c = cell(i.key, t);
            const best = bestByThreads.get(t) === i.key;
            return (
              <td class:list={['num', { best }]}>
                {c ? fmt(c.mops) : '—'}
              </td>
            );
          })}
        </tr>
      ))}
    </tbody>
  </table>
  <figcaption>
    Millions of allocate + touch + free operations per second, best of {data.bestOf}, for {data.iters.toLocaleString()}
    {' '}operations per thread of a {data.block}-byte block, on a {data.cpuThreads}-thread CPU. Higher is
    better. Regenerate with <code>npm run bench:alloc</code> (captured {data.generatedOn}).
    {data.tcmalloc && (
      <><br /><strong>tcmalloc (gperftools)</strong> is the identical binary run under{' '}
      <code>LD_PRELOAD={data.tcmallocPath}</code>.{' '}
      {data.percpu && <><strong>tcmalloc (Google)</strong> is the same source statically linked against the newer{' '}
      <code>google/tcmalloc</code> via Bazel (it ships no preloadable library).</>}</>
    )}
  </figcaption>
</figure>

<style>
  .abench { margin: 1.75rem 0; overflow-x: auto; }
  .abench table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  .abench th, .abench td { padding: 0.45rem 0.7rem; border-bottom: 1px solid var(--rule); text-align: left; }
  .abench th.num, .abench td.num { text-align: right; font-variant-numeric: tabular-nums; font-family: 'JetBrains Mono', ui-monospace, monospace; }
  .abench td.threads { font-variant-numeric: tabular-nums; font-family: 'JetBrains Mono', ui-monospace, monospace; color: var(--muted); }
  .abench thead th { color: var(--muted); font-weight: 600; border-bottom: 2px solid var(--rule); }
  .abench td.best { color: var(--fg); font-weight: 700; }
  .abench figcaption { margin-top: 0.6rem; font-size: 0.82rem; color: var(--muted); }
  .abench figcaption code { font-family: 'JetBrains Mono', ui-monospace, monospace; }
</style>
