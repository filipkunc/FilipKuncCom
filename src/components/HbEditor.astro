---
// The hb-gpu text editor demo, embedded from scripts/hb-editor.
---

<div id="hb-editor-demo" class="hb-demo">
  <div class="row">
    <label>font
      <select id="font">
        <option value="EBGaramond" selected>EB Garamond (fi/ffi ligatures)</option>
        <option value="Inter">Inter (no f-ligatures by design)</option>
        <option value="FiraCode">Fira Code (caret-safe programming ligatures)</option>
      </select>
    </label>
    <span id="status">loading wasm…</span>
  </div>
  <!-- #region input-proxy-dom -->
  <div class="editor-wrap">
    <canvas id="canvas"></canvas>
    <textarea
      id="input-proxy"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"></textarea>
    <p class="hb-loading">loading wasm + font…</p>
  </div>
  <!-- #endregion input-proxy-dom -->
</div>

<style>
  .hb-demo { margin: 1.5rem 0; }
  .row { display: flex; gap: 1rem; align-items: center; margin: 0 0 0.5rem; flex-wrap: wrap; }
  #status { color: var(--muted, #666); font-size: 0.85rem; }
  canvas {
    width: 100%; height: 220px; border: 1px solid var(--rule, #ccc);
    border-radius: 6px; display: block; cursor: text; touch-action: none;
    background: var(--bg, #fff);
  }
  /* #region input-proxy-css */
  /* Invisible but focusable: receives keyboard, IME, and clipboard events. */
  .editor-wrap { position: relative; }
  #input-proxy {
    position: absolute; left: 0; top: 0; width: 1px; height: 1px;
    opacity: 0; border: none; padding: 0; resize: none; outline: none;
    overflow: hidden; pointer-events: none;
  }
  /* #endregion input-proxy-css */
  .hb-loading {
    position: absolute; inset: 0; display: flex; align-items: center;
    justify-content: center; margin: 0; pointer-events: none;
    color: var(--muted, #666); font-size: 0.9rem;
    animation: hb-pulse 1.2s ease-in-out infinite;
  }
  @keyframes hb-pulse { 50% { opacity: 0.4; } }
</style>

<script>
  import { mountEditorDemo } from '../../scripts/hb-editor/src/demo-editor.mjs';
  import interUrl from '../../scripts/hb-editor/fonts/Inter-subset.ttf?url';
  import garamondUrl from '../../scripts/hb-editor/fonts/EBGaramond-subset.ttf?url';
  import firaUrl from '../../scripts/hb-editor/fonts/FiraCode-subset.ttf?url';

  const root = document.getElementById('hb-editor-demo');
  mountEditorDemo(root, {
    fontUrls: { Inter: interUrl, EBGaramond: garamondUrl, FiraCode: firaUrl },
  }).then(() => root.querySelector('.hb-loading')?.remove());
</script>
