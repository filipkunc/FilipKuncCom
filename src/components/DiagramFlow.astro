---
// Overview diagram for the type-json-validator post: one inferred type feeding
// two consumers. Hand-authored SVG so it renders server-side, themes via the
// site CSS variables, needs no JS, and never clips its labels.
---

<figure class="diagram">
  <svg viewBox="0 0 720 360" role="img"
    aria-label="A JSON value is inferred into a type Root, which feeds both the live squiggles and a generated validate function.">
    <defs>
      <marker id="flow-arrow" viewBox="0 0 10 10" refX="8.5" refY="5"
        markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" />
      </marker>
    </defs>

    <!-- edges -->
    <line class="edge" x1="360" y1="74" x2="360" y2="146" marker-end="url(#flow-arrow)" />
    <path class="edge" d="M322,204 C 275,240 215,250 170,284" marker-end="url(#flow-arrow)" />
    <path class="edge" d="M398,204 C 465,240 505,250 543,284" marker-end="url(#flow-arrow)" />

    <!-- edge labels -->
    <text class="edge-label" x="372" y="114" text-anchor="start">infer</text>
    <text class="edge-label" x="232" y="244" text-anchor="middle">hidden file + TS worker</text>
    <text class="edge-label" x="512" y="244" text-anchor="middle">Compiler API + transpile</text>

    <!-- boxes -->
    <g class="node">
      <rect class="box" x="285" y="18" width="150" height="56" rx="8" />
      <text class="box-label" x="360" y="46">JSON value</text>
    </g>
    <g class="node">
      <rect class="box" x="285" y="148" width="150" height="56" rx="8" />
      <text class="box-label" x="360" y="176">type Root</text>
    </g>
    <g class="node">
      <rect class="box" x="70" y="286" width="190" height="56" rx="8" />
      <text class="box-label" x="165" y="314">live squiggles</text>
    </g>
    <g class="node">
      <rect class="box" x="388" y="286" width="320" height="56" rx="8" />
      <text class="box-label box-code" x="548" y="314">validate(value): value is Root</text>
    </g>
  </svg>
  <figcaption>One inferred type, two consumers: the live checker and the generated validator.</figcaption>
</figure>
