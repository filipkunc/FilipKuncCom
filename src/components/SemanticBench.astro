---
// Renders the semantic-search results from semantic-results.json, produced by
// running semantic/embed.py over the Node.js tree. Shows what the index cost to
// build, then a few natural-language queries and the code chunks they return,
// none of which share their key words with the files they match. Each hit
// expands to the real source the model matched and links to those exact lines
// on GitHub (pinned to the commit the index was built from), so the results are
// checkable rather than asserted.
import data from '../content/posts/code-search/semantic-results.json';

type Hit = { path: string; start: number; end: number; score: number; text: string };
type Example = { query: string; ms: number; results: Hit[] };

const examples = data.examples as Example[];
const ref = data.ref as string;
const repo = data.repo as string;
const lines = (h: Hit) => (h.start === h.end ? `${h.start}` : `${h.start}–${h.end}`);
const github = (h: Hit) => `https://github.com/${repo}/blob/${ref}/${h.path}#L${h.start}-L${h.end}`;
const shortRef = ref.slice(0, 7);
const embedTime =
  data.embedSeconds < 120 ? `${Math.round(data.embedSeconds)} s` : `${Math.round(data.embedSeconds / 60)} min`;
const TOP = 5;
---

<figure class="sbench">
  <figcaption class="top">
    {data.scope}: <strong>{data.files.toLocaleString()}</strong> files chunked on syntax into
    {' '}<strong>{data.chunks.toLocaleString()}</strong> pieces, embedded with
    {' '}<code>{data.model}</code> ({data.dim}-d) on a {data.gpu} in
    {' '}<strong>{embedTime}</strong>, into a
    {' '}<strong>{(data.indexBytes / 1e6).toFixed(0)} MB</strong> HNSW index.
  </figcaption>

  {examples.map((ex) => (
    <div class="ex">
      <div class="q">“{ex.query}”<span class="lat">{ex.ms.toFixed(0)} ms</span></div>
      <ul>
        {ex.results.slice(0, TOP).map((h) => (
          <li>
            <details>
              <summary>
                <span class="score" style={`--w:${Math.round(h.score * 100)}%`}>{h.score.toFixed(2)}</span>
                <code class="path">{h.path}:{lines(h)}</code>
                <span class="hint">view</span>
              </summary>
              <div class="body">
                <pre><code>{h.text}</code></pre>
                <a class="gh" href={github(h)} target="_blank" rel="noopener noreferrer">
                  {h.path}:{lines(h)} on GitHub ↗
                </a>
              </div>
            </details>
          </li>
        ))}
      </ul>
    </div>
  ))}

  <figcaption>
    Cosine similarity (higher is nearer). Click a hit to see the code the model matched and open it at
    {' '}<code>nodejs/node@{shortRef}</code>. The per-query time is almost all the cost of embedding the
    question through the model; the HNSW search itself is sub-millisecond. Generated by
    {' '}<code>uv run embed.py</code>, captured {data.generatedOn}.
  </figcaption>
</figure>

<style>
  .sbench { margin: 1.75rem 0; }
  .sbench figcaption { font-size: 0.82rem; color: var(--muted); }
  .sbench figcaption.top { margin-bottom: 1rem; }
  .sbench figcaption:not(.top) { margin-top: 0.8rem; }
  .sbench figcaption code, .sbench .q code, .sbench .path, .sbench pre code { font-family: 'JetBrains Mono', ui-monospace, monospace; }
  .sbench .ex { margin: 0.9rem 0; }
  .sbench .q { font-weight: 600; color: var(--fg); margin-bottom: 0.35rem; }
  .sbench .q .lat { margin-left: 0.6rem; font-weight: 400; font-size: 0.8rem; color: var(--muted); font-family: 'JetBrains Mono', ui-monospace, monospace; }
  .sbench ul { list-style: none; margin: 0; padding: 0; }
  .sbench li { padding: 0.1rem 0; font-size: 0.88rem; }

  .sbench summary {
    display: flex; align-items: center; gap: 0.6rem; cursor: pointer;
    padding: 0.15rem 0; list-style: none;
  }
  .sbench summary::-webkit-details-marker { display: none; }
  .sbench .path { color: var(--muted); }
  .sbench details[open] .path { color: var(--fg); }
  .sbench .hint {
    margin-left: auto; font-size: 0.72rem; color: var(--muted);
    border: 1px solid var(--rule); border-radius: 3px; padding: 0.05rem 0.4rem;
  }
  .sbench summary:hover .hint { color: var(--fg); border-color: var(--fg); }
  .sbench details[open] .hint { color: var(--fg); }

  .sbench .body { margin: 0.3rem 0 0.7rem 3.8rem; }
  .sbench pre {
    margin: 0; padding: 0.7rem 0.9rem; overflow-x: auto;
    background: var(--code-bg, rgba(127, 127, 127, 0.08));
    border: 1px solid var(--rule); border-radius: 5px;
    font-size: 0.8rem; line-height: 1.5; max-height: 22rem; overflow-y: auto;
  }
  .sbench pre code { color: var(--fg); white-space: pre; }
  .sbench .gh {
    display: inline-block; margin-top: 0.45rem; font-size: 0.78rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
  }

  .sbench .score {
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 0.78rem; color: var(--fg);
    background: linear-gradient(to right, var(--rule) var(--w), transparent var(--w));
    padding: 0.05rem 0.4rem; border-radius: 3px; min-width: 3.2rem; text-align: right; flex: none;
  }
</style>
