---
// A diagram panel for the rts-flow-fields post: a canvas illustration of
// what a nearby code excerpt does (scripts/flowfield/js/diagrams.mjs), or
// the bit-layout figure for kind="bits". Mounted lazily like the demos.
interface Props {
  kind: 'bits' | 'wavefront' | 'flowpick' | 'los' | 'steer' | 'terrain' | 'contagion';
  caption?: string;
}
const { kind, caption } = Astro.props;

const bitRows = [
  { name: 'cost', bits: [{ label: '8 bits · terrain cost, 255 = wall', grow: 8 }] },
  {
    name: 'integration',
    bits: [
      { label: '16 bits · integrated cost to goal', grow: 16 },
      { label: 'flags · LOS, wavefront', grow: 8 },
    ],
  },
  {
    name: 'flow',
    bits: [
      { label: '4 bits · direction LUT index', grow: 4 },
      { label: 'flags · pathable, LOS', grow: 4 },
    ],
  },
];
---

<figure class="ffd" data-ff-diagram={kind === 'bits' ? undefined : kind}>
  {
    kind === 'bits' ? (
      <div class="ffd-bits">
        {bitRows.map((row) => (
          <div class="ffd-bitrow">
            <span class="ffd-bitname">{row.name}</span>
            <span class="ffd-boxes">
              {row.bits.map((b) => (
                <span class="ffd-box" style={`flex-grow: ${b.grow}`}>
                  {b.label}
                </span>
              ))}
            </span>
          </div>
        ))}
      </div>
    ) : (
      <div class="ffd-stage"></div>
    )
  }
  {
    ['wavefront', 'steer', 'contagion'].includes(kind) && (
      <button type="button" class="ffd-play">
        {kind === 'wavefront' ? '▶ play the wave' : '▶ play'}
      </button>
    )
  }
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style is:global>
  /* Diagram palette, themed the same way as the site palette in Layout.astro:
     dark defaults, [data-theme="light"] for the live toggle, and the media
     query as the JS-off fallback. The numeric data colors (gradients) are
     mirrored in scripts/flowfield/js/diagrams.mjs, which re-renders on theme
     change. */
  :root {
    --ffd-floor: #10151c;
    --ffd-grid: #222c39;
    --ffd-panel: #161d27;
    --ffd-wall: #566374;
    --ffd-mud: #6e542e;
    --ffd-mud-bright: #c9a36a;
    --ffd-text: #9aa7b8;
    --ffd-bright: #e8eef5;
    --ffd-accent: #ffb454;
    --ffd-agent: #6bd9ff;
    --ffd-parked: #ff7eb6;
    --ffd-stalled: #ffd166;
    --ffd-goal: #ff5d5d;
    --ffd-bad: #ff6b6b;
    --ffd-ok: #7ee787;
    --ffd-edge: #44516a;
    --ffd-box: #182230;
    --ffd-box-border: #344153;
    --ffd-box-text: #c7d2de;
  }
  :root[data-theme='light'] {
    --ffd-floor: #f4f6f9;
    --ffd-grid: #dde3ea;
    --ffd-panel: #e8edf3;
    --ffd-wall: #8e9aaa;
    --ffd-mud: #c9ad79;
    --ffd-mud-bright: #9a7b45;
    --ffd-text: #57636f;
    --ffd-bright: #18222e;
    --ffd-accent: #d97706;
    --ffd-agent: #0993d3;
    --ffd-parked: #e0488e;
    --ffd-stalled: #d3a012;
    --ffd-goal: #e23d3d;
    --ffd-bad: #d64545;
    --ffd-ok: #1da653;
    --ffd-edge: #99a5b4;
    --ffd-box: #e8edf3;
    --ffd-box-border: #c2ccd8;
    --ffd-box-text: #303b48;
  }
  @media (prefers-color-scheme: light) {
    :root:not([data-theme]) {
      --ffd-floor: #f4f6f9;
      --ffd-grid: #dde3ea;
      --ffd-panel: #e8edf3;
      --ffd-wall: #8e9aaa;
      --ffd-mud: #c9ad79;
      --ffd-mud-bright: #9a7b45;
      --ffd-text: #57636f;
      --ffd-bright: #18222e;
      --ffd-accent: #d97706;
      --ffd-agent: #0993d3;
      --ffd-parked: #e0488e;
      --ffd-stalled: #d3a012;
      --ffd-goal: #e23d3d;
      --ffd-bad: #d64545;
      --ffd-ok: #1da653;
      --ffd-edge: #99a5b4;
      --ffd-box: #e8edf3;
      --ffd-box-border: #c2ccd8;
      --ffd-box-text: #303b48;
    }
  }
</style>

<style>
  .ffd {
    position: relative;
    margin: 1.2rem 0 1.6rem;
  }
  .ffd-play {
    position: absolute;
    top: 10px;
    right: 10px;
    font: inherit;
    font-size: 0.8rem;
    padding: 0.3rem 0.7rem;
    /* Sits on the figure panel, so it themes with the figure palette. */
    color: var(--ffd-bright);
    background: var(--ffd-panel);
    border: 1px solid var(--ffd-box-border);
    border-radius: 999px;
    cursor: pointer;
  }
  .ffd-play:hover {
    border-color: var(--ffd-text);
  }
  .ffd-stage :global(svg) {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--rule);
    border-radius: 4px;
    background: var(--ffd-floor);
  }
  .ffd figcaption {
    margin-top: 0.45rem;
    font-size: 0.82rem;
    color: var(--muted);
    text-align: center;
  }
  .ffd-bits {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 0.9rem;
    border: 1px solid var(--rule);
    border-radius: 4px;
    background: var(--ffd-floor);
  }
  .ffd-bitrow {
    display: flex;
    align-items: stretch;
    gap: 0.6rem;
  }
  .ffd-bitname {
    flex: 0 0 5.5rem;
    align-self: center;
    text-align: right;
    font-size: 0.82rem;
    color: var(--muted);
  }
  .ffd-boxes {
    display: flex;
    flex: 1;
    gap: 3px;
  }
  .ffd-box {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2.4rem;
    padding: 0.2rem 0.45rem;
    border: 1px solid var(--ffd-box-border);
    border-radius: 3px;
    background: var(--ffd-box);
    color: var(--ffd-box-text);
    font-size: 0.74rem;
    text-align: center;
    line-height: 1.25;
  }
  @media (max-width: 640px) {
    .ffd-bitrow {
      flex-direction: column;
      gap: 0.25rem;
    }
    .ffd-bitname {
      flex: none;
      text-align: left;
    }
  }
</style>

<script>
  import { mountWhenVisible } from '../../scripts/hb-editor/src/lazy.mjs';

  for (const fig of document.querySelectorAll<HTMLElement>('[data-ff-diagram]')) {
    mountWhenVisible(fig, async () => {
      const { mountDiagram } = await import('../../scripts/flowfield/js/diagrams.mjs');
      const stage = fig.querySelector('.ffd-stage');
      const button = fig.querySelector('button.ffd-play');
      if (stage) mountDiagram(stage, fig.dataset.ffDiagram, { button });
    });
  }
</script>
