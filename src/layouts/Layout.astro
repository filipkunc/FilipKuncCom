---
import 'katex/dist/katex.min.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const fullTitle = title === 'filipkunc.com' ? title : `${title} — filipkunc.com`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="brand">filipkunc.com</a>
        <span class="spacer"></span>
        <a href="/posts">posts</a>
        <a href="/meshmaker">meshmaker</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <small>Built with Astro. <a href="https://github.com/filipkunc">@filipkunc</a> on GitHub.</small>
    </footer>

    <style is:global>
      :root {
        --bg: #0e0e10;
        --fg: #e9e9ea;
        --muted: #8a8a8e;
        --link: #7aa9ff;
        --accent: #ff6b35;
        --rule: #2a2a2e;
        --maxw: 72ch;
      }
      @media (min-width: 900px) {
        :root { --maxw: 80ch; }
      }
      @media (prefers-color-scheme: light) {
        :root {
          --bg: #fafafa;
          --fg: #1a1a1c;
          --muted: #5a5a5e;
          --link: #2b5fb8;
          --accent: #c34a16;
          --rule: #e2e2e6;
        }
      }
      * { box-sizing: border-box; }
      html { color-scheme: dark light; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font: 16px/1.6 ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--link); text-decoration: none; }
      a:hover { text-decoration: underline; }
      header, main, footer { max-width: var(--maxw); margin: 0 auto; padding: 1rem; }
      header { padding-top: 1.5rem; }
      header nav { display: flex; gap: 1.25rem; align-items: baseline; border-bottom: 1px solid var(--rule); padding-bottom: 0.75rem; }
      header .brand { font-weight: 600; }
      header .spacer { flex: 1; }
      main { padding-top: 2rem; padding-bottom: 4rem; }
      footer { color: var(--muted); border-top: 1px solid var(--rule); }
      h1, h2, h3 { line-height: 1.25; }
      h1 { font-size: 2rem; margin: 0 0 0.5rem; }
      h2 { font-size: 1.4rem; margin: 2rem 0 0.5rem; }
      h3 { font-size: 1.15rem; margin: 1.5rem 0 0.5rem; }
      p { margin: 1rem 0; }
      pre, code { font-family: ui-monospace, SFMono-Regular, "Cascadia Mono", Menlo, monospace; }
      pre {
        background: color-mix(in srgb, var(--fg) 6%, transparent);
        padding: 1rem; overflow-x: auto; border-radius: 6px;
        font-size: 0.9em;
      }
      code:not(pre code) {
        background: color-mix(in srgb, var(--fg) 8%, transparent);
        padding: 0.1em 0.35em; border-radius: 4px; font-size: 0.92em;
      }
      blockquote {
        margin: 1.25rem 0; padding: 0.5rem 1rem;
        border-left: 3px solid var(--accent); color: var(--muted);
      }
      hr { border: 0; border-top: 1px solid var(--rule); margin: 2rem 0; }
      ul, ol { padding-left: 1.5rem; }
      img, video { max-width: 100%; height: auto; display: block; margin: 1.5rem auto; border-radius: 4px; }
      video { background: #000; }
      a > img { transition: box-shadow 0.15s ease; }
      a:hover > img, a:focus-visible > img {
        box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 60%, transparent);
      }
      .post-list { list-style: none; padding: 0; }
      .post-list li { padding: 0.75rem 0; border-bottom: 1px solid var(--rule); }
      .post-meta { color: var(--muted); font-size: 0.9rem; }
      table {
        border-collapse: collapse;
        margin: 1.25rem 0;
        font-size: 0.95em;
      }
      th, td {
        padding: 0.45rem 0.75rem;
        border: 1px solid var(--rule);
        text-align: left;
      }
      th {
        font-weight: 600;
        background: color-mix(in srgb, var(--fg) 5%, transparent);
      }
      figure.scoreboard { margin: 1.5rem 0; }
      figure.scoreboard table { width: 100%; }
      figure.scoreboard th:not(:first-child),
      figure.scoreboard td:not(:first-child) { text-align: center; }
      figure.scoreboard figcaption {
        margin-top: 0.5rem;
        color: var(--muted);
        font-size: 0.85em;
      }
      /* Hand-authored SVG flow diagrams. Static markup, themed by these vars,
         no JS — see src/components/Diagram*.astro. */
      figure.diagram { margin: 1.75rem 0; text-align: center; }
      figure.diagram svg { max-width: 100%; height: auto; }
      figure.diagram .box {
        fill: color-mix(in srgb, var(--fg) 4%, var(--bg));
        stroke: var(--rule);
        stroke-width: 1;
      }
      figure.diagram .box-label {
        fill: var(--fg);
        font: 15px ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        text-anchor: middle;
        dominant-baseline: middle;
      }
      figure.diagram .box-code {
        font-family: ui-monospace, SFMono-Regular, "Cascadia Mono", Menlo, monospace;
        font-size: 13.5px;
      }
      figure.diagram .edge { fill: none; stroke: var(--accent); stroke-width: 1.5; }
      figure.diagram .edge-label {
        fill: var(--muted);
        font: 13px ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        /* A background-colored halo so an edge line behind a label is occluded
           instead of striking through the text. */
        paint-order: stroke;
        stroke: var(--bg);
        stroke-width: 4px;
        stroke-linejoin: round;
      }
      figure.diagram marker path { fill: var(--accent); }
      figure.diagram figcaption {
        margin-top: 0.75rem;
        color: var(--muted);
        font-size: 0.85em;
      }
      .code-wrap { position: relative; }
      .copy-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        color: var(--muted);
        background: color-mix(in srgb, var(--bg) 80%, var(--fg) 8%);
        border: 1px solid var(--rule);
        border-radius: 4px;
        cursor: pointer;
        opacity: 0.4;
        transition: opacity 0.15s ease, color 0.15s ease;
      }
      .copy-btn svg { width: 0.95rem; height: 0.95rem; display: block; }
      .copy-btn:hover { color: var(--fg); }
      .copy-btn:focus-visible { opacity: 1; }
      .copy-btn.is-copied { color: var(--accent); opacity: 1; }
      .code-wrap > .copy-btn {
        position: absolute;
        top: 0.4rem;
        right: 0.4rem;
        width: 1.85rem;
        height: 1.85rem;
      }
      .code-wrap:hover > .copy-btn { opacity: 1; }
      .code-file-label {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
      }
      .code-file-label > .copy-btn {
        width: 1.4rem;
        height: 1.4rem;
        background: transparent;
        border-color: transparent;
        opacity: 0.6;
      }
      .code-file-label > .copy-btn svg { width: 0.85rem; height: 0.85rem; }
      .code-file:hover .code-file-label > .copy-btn,
      .snippet-section:hover .code-file-label > .copy-btn { opacity: 1; }
    </style>

    <script>
      // Wrap every <pre> inside <main> with a div and append a Copy button.
      // Idempotent so re-runs (e.g. dev HMR) don't double up.
      const ICON_COPY = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
      const ICON_CHECK = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';

      document.querySelectorAll('main pre').forEach((pre) => {
        if (pre.parentElement?.classList.contains('code-wrap')) return;
        if (pre.parentElement?.querySelector(':scope > .code-file-label .copy-btn')) return;

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'copy-btn';
        btn.setAttribute('aria-label', 'Copy code');
        btn.innerHTML = ICON_COPY;
        btn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText((pre as HTMLElement).innerText);
            btn.innerHTML = ICON_CHECK;
            btn.classList.add('is-copied');
          } catch {
            btn.setAttribute('aria-label', 'Copy failed');
          }
          setTimeout(() => {
            btn.innerHTML = ICON_COPY;
            btn.classList.remove('is-copied');
            btn.setAttribute('aria-label', 'Copy code');
          }, 1500);
        });

        const label = pre.parentElement?.querySelector(':scope > .code-file-label');
        if (label) {
          label.appendChild(btn);
        } else {
          const wrap = document.createElement('div');
          wrap.className = 'code-wrap';
          pre.parentNode?.insertBefore(wrap, pre);
          wrap.appendChild(pre);
          wrap.appendChild(btn);
        }
      });
    </script>
  </body>
</html>
