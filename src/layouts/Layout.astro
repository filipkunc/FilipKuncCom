---
import 'katex/dist/katex.min.css';

interface Props {
  title: string;
  description?: string;
  /** Page type for Open Graph. Posts pass 'article'; everything else is a 'website'. */
  type?: 'website' | 'article';
  /** Site-relative or absolute preview image. Defaults to the site-wide banner. */
  image?: string;
  /** ISO publish date, emitted as article:published_time for 'article' pages. */
  publishedDate?: Date;
}

const {
  title,
  description,
  type = 'website',
  image = '/og-default.png',
  publishedDate,
} = Astro.props;
const fullTitle = title === 'filipkunc.com' ? title : `${title} — filipkunc.com`;

// Fall back to the site tagline so pages without their own description still
// get a sensible card on social and in search results.
const SITE_DESCRIPTION = 'Notes, projects, and experiments by Filip Kunc.';
const metaDescription = description ?? SITE_DESCRIPTION;

// Astro.site is https://filipkunc.com. Build absolute URLs for canonical and
// og:image — social scrapers and search engines require fully-qualified ones.
// trailingSlash is 'never', so normalise '/posts/' -> '/posts' (root stays '/').
const canonicalPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonicalURL = new URL(canonicalPath, Astro.site).href;
const imageURL = new URL(image, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <meta name="description" content={metaDescription} />
    <meta name="author" content="Filip Kunc" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph: how the link renders when shared (LinkedIn, Slack, etc.) -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="filipkunc.com" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    {type === 'article' && publishedDate && (
      <meta property="article:published_time" content={publishedDate.toISOString()} />
    )}
    {type === 'article' && <meta property="article:author" content="Filip Kunc" />}

    <!-- Twitter/X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={imageURL} />

    <link rel="alternate" type="application/rss+xml" title="filipkunc.com" href="/rss.xml" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <title>{fullTitle}</title>
    <script is:inline>
      // Resolve the active theme before first paint to avoid a flash: an explicit
      // choice in localStorage wins, otherwise fall back to the OS preference.
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var theme =
            saved === 'light' || saved === 'dark'
              ? saved
              : window.matchMedia('(prefers-color-scheme: light)').matches
                ? 'light'
                : 'dark';
          document.documentElement.dataset.theme = theme;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="brand">
          <img src="/apple-touch-icon.png" alt="My dog" class="brand-avatar" width="28" height="28" />
          filipkunc.com
        </a>
        <span class="spacer"></span>
        <a href="/posts">posts</a>
        <a href="/meshmaker">meshmaker</a>
        <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark and light theme" title="Toggle theme">
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <small>Built with Astro. <a href="https://github.com/filipkunc">@filipkunc</a> on GitHub.</small>
    </footer>

    <style is:global>
      :root {
        /* Dark palette: the default, and the fallback when JS is off and the OS
           expresses no light preference. */
        --bg: #0e0e10;
        --fg: #e9e9ea;
        --muted: #8a8a8e;
        --link: #7aa9ff;
        --accent: #ff6b35;
        --rule: #2a2a2e;
        --maxw: 72ch;
      }
      @media (min-width: 900px) {
        :root { --maxw: 80ch; }
      }
      /* Light palette. The inline head script resolves the active theme to an
         explicit data-theme, so [data-theme="light"] is the live toggle path.
         The media query is the JS-off fallback: honor the OS only when the
         visitor has expressed no choice (no data-theme attribute). */
      :root[data-theme="light"] {
        --bg: #fafafa;
        --fg: #1a1a1c;
        --muted: #5a5a5e;
        --link: #2b5fb8;
        --accent: #c34a16;
        --rule: #e2e2e6;
      }
      @media (prefers-color-scheme: light) {
        :root:not([data-theme]) {
          --bg: #fafafa;
          --fg: #1a1a1c;
          --muted: #5a5a5e;
          --link: #2b5fb8;
          --accent: #c34a16;
          --rule: #e2e2e6;
        }
      }
      * { box-sizing: border-box; }
      html { color-scheme: dark light; }
      :root[data-theme="dark"] { color-scheme: dark; }
      :root[data-theme="light"] { color-scheme: light; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font: 16px/1.6 ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--link); text-decoration: none; }
      a:hover { text-decoration: underline; }
      header, main, footer { max-width: var(--maxw); margin: 0 auto; padding: 1rem; }
      header { padding-top: 0.75rem; padding-bottom: 0.5rem; }
      header nav { display: flex; gap: 1.25rem; align-items: center; border-bottom: 1px solid var(--rule); padding-bottom: 0.75rem; }
      header .brand { display: inline-flex; align-items: center; gap: 0.55rem; font-weight: 600; }
      header .brand-avatar { width: 1.75rem; height: 1.75rem; border-radius: 50%; flex: none; }
      header .spacer { flex: 1; }
      @media (max-width: 30rem) {
        header, main, footer { padding-left: 0.75rem; padding-right: 0.75rem; }
        header nav { gap: 0.7rem; }
        header .brand { gap: 0.4rem; }
      }
      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        padding: 0;
        color: var(--muted);
        background: transparent;
        border: 1px solid var(--rule);
        border-radius: 50%;
        cursor: pointer;
        transition: color 0.15s ease, border-color 0.15s ease;
      }
      .theme-toggle:hover { color: var(--fg); border-color: var(--fg); }
      .theme-toggle:focus-visible { color: var(--fg); }
      .theme-toggle svg { width: 1.05rem; height: 1.05rem; display: block; }
      /* Show the icon for the theme you'd switch TO: sun while dark, moon while light. */
      .theme-toggle .icon-moon { display: none; }
      .theme-toggle .icon-sun { display: block; }
      :root[data-theme="light"] .theme-toggle .icon-sun { display: none; }
      :root[data-theme="light"] .theme-toggle .icon-moon { display: block; }
      @media (prefers-color-scheme: light) {
        :root:not([data-theme]) .theme-toggle .icon-sun { display: none; }
        :root:not([data-theme]) .theme-toggle .icon-moon { display: block; }
      }
      main { padding-top: 1rem; padding-bottom: 4rem; }
      footer { color: var(--muted); border-top: 1px solid var(--rule); }
      h1, h2, h3 { line-height: 1.25; }
      h1 { font-size: 2rem; margin: 0 0 0.5rem; }
      h2 { font-size: 1.4rem; margin: 2rem 0 0.5rem; }
      h3 { font-size: 1.15rem; margin: 1.5rem 0 0.5rem; }
      p { margin: 1rem 0; }
      pre, code { font-family: ui-monospace, SFMono-Regular, "Cascadia Mono", Menlo, monospace; }
      pre {
        background: color-mix(in srgb, var(--fg) 6%, transparent);
        padding: 1rem; overflow-x: auto; border-radius: 6px;
        font-size: 0.9em;
      }
      code:not(pre code) {
        background: color-mix(in srgb, var(--fg) 8%, transparent);
        padding: 0.1em 0.35em; border-radius: 4px; font-size: 0.92em;
      }
      kbd {
        font-family: ui-monospace, SFMono-Regular, "Cascadia Mono", Menlo, monospace;
        font-size: 0.82em;
        padding: 0.1em 0.45em;
        border: 1px solid color-mix(in srgb, var(--fg) 25%, transparent);
        border-bottom-width: 2px;
        border-radius: 5px;
        background: color-mix(in srgb, var(--fg) 5%, transparent);
        white-space: nowrap;
      }
      /* Shiki bakes the dark palette inline (see astro.config defaultColor) and
         stashes the light palette in --shiki-light* vars. Swap to it when the
         light theme is active, either via the toggle or (JS off) the OS. */
      :root[data-theme="light"] .astro-code,
      :root[data-theme="light"] .astro-code span {
        color: var(--shiki-light) !important;
        background-color: var(--shiki-light-bg) !important;
        font-style: var(--shiki-light-font-style) !important;
        font-weight: var(--shiki-light-font-weight) !important;
        text-decoration: var(--shiki-light-text-decoration) !important;
      }
      @media (prefers-color-scheme: light) {
        :root:not([data-theme]) .astro-code,
        :root:not([data-theme]) .astro-code span {
          color: var(--shiki-light) !important;
          background-color: var(--shiki-light-bg) !important;
          font-style: var(--shiki-light-font-style) !important;
          font-weight: var(--shiki-light-font-weight) !important;
          text-decoration: var(--shiki-light-text-decoration) !important;
        }
      }
      blockquote {
        margin: 1.25rem 0; padding: 0.5rem 1rem;
        border-left: 3px solid var(--accent); color: var(--muted);
      }
      hr { border: 0; border-top: 1px solid var(--rule); margin: 2rem 0; }
      ul, ol { padding-left: 1.5rem; }
      img, video { max-width: 100%; height: auto; display: block; margin: 1.5rem auto; border-radius: 4px; }
      video { background: #000; }
      /* Accent ring on hover for interactive images: linked images (e.g. the
         Old Stuff demos) and zoomable content images (open the lightbox). */
      a > img, main img.zoomable { transition: box-shadow 0.15s ease; }
      a:hover > img, a:focus-visible > img, main img.zoomable:hover {
        box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 60%, transparent);
      }
      .post-list { list-style: none; padding: 0; }
      .post-list li { padding: 0.75rem 0; border-bottom: 1px solid var(--rule); }
      .post-meta { color: var(--muted); font-size: 0.9rem; }
      table {
        border-collapse: collapse;
        margin: 1.25rem 0;
        font-size: 0.95em;
      }
      th, td {
        padding: 0.45rem 0.75rem;
        border: 1px solid var(--rule);
        text-align: left;
      }
      th {
        font-weight: 600;
        background: color-mix(in srgb, var(--fg) 5%, transparent);
      }
      figure.scoreboard { margin: 1.5rem 0; }
      figure.scoreboard table { width: 100%; }
      figure.scoreboard th:not(:first-child),
      figure.scoreboard td:not(:first-child) { text-align: center; }
      figure.scoreboard figcaption {
        margin-top: 0.5rem;
        color: var(--muted);
        font-size: 0.85em;
      }
      /* Hand-authored SVG flow diagrams. Static markup, themed by these vars,
         no JS — see src/components/Diagram*.astro. */
      figure.diagram { margin: 1.75rem 0; text-align: center; }
      figure.diagram svg { max-width: 100%; height: auto; }
      figure.diagram .box {
        fill: color-mix(in srgb, var(--fg) 4%, var(--bg));
        stroke: var(--rule);
        stroke-width: 1;
      }
      figure.diagram .box-label {
        fill: var(--fg);
        font: 15px ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        text-anchor: middle;
        dominant-baseline: middle;
      }
      figure.diagram .box-code {
        font-family: ui-monospace, SFMono-Regular, "Cascadia Mono", Menlo, monospace;
        font-size: 13.5px;
      }
      figure.diagram .edge { fill: none; stroke: var(--accent); stroke-width: 1.5; }
      figure.diagram .edge-label {
        fill: var(--muted);
        font: 13px ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        /* A background-colored halo so an edge line behind a label is occluded
           instead of striking through the text. */
        paint-order: stroke;
        stroke: var(--bg);
        stroke-width: 4px;
        stroke-linejoin: round;
      }
      figure.diagram marker path { fill: var(--accent); }
      figure.diagram figcaption {
        margin-top: 0.75rem;
        color: var(--muted);
        font-size: 0.85em;
      }
      .code-wrap { position: relative; }
      .copy-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        color: var(--muted);
        background: color-mix(in srgb, var(--bg) 80%, var(--fg) 8%);
        border: 1px solid var(--rule);
        border-radius: 4px;
        cursor: pointer;
        opacity: 0.4;
        transition: opacity 0.15s ease, color 0.15s ease;
      }
      .copy-btn svg { width: 0.95rem; height: 0.95rem; display: block; }
      .copy-btn:hover { color: var(--fg); }
      .copy-btn:focus-visible { opacity: 1; }
      .copy-btn.is-copied { color: var(--accent); opacity: 1; }
      .code-wrap > .copy-btn {
        position: absolute;
        top: 0.4rem;
        right: 0.4rem;
        width: 1.85rem;
        height: 1.85rem;
      }
      .code-wrap:hover > .copy-btn { opacity: 1; }
      .code-file-label {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
      }
      .code-file-label > .copy-btn {
        width: 1.4rem;
        height: 1.4rem;
        background: transparent;
        border-color: transparent;
        opacity: 0.6;
      }
      .code-file-label > .copy-btn svg { width: 0.85rem; height: 0.85rem; }
      .code-file:hover .code-file-label > .copy-btn,
      .snippet-section:hover .code-file-label > .copy-btn { opacity: 1; }

      /* Click-to-zoom lightbox for content images (see the script below). The
         pointer hint is only applied once JS marks images as zoomable, so it
         never appears when the lightbox would not actually open. The zoom-in /
         zoom-out cursors live inside the overlay, where clicking truly changes
         magnification. */
      main img.zoomable { cursor: pointer; }
      .lightbox {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        overflow: auto;
        background: color-mix(in srgb, var(--bg) 12%, rgba(0, 0, 0, 0.92));
        overscroll-behavior: contain;
      }
      .lightbox.is-open { display: flex; }
      .lightbox img {
        max-width: 100%;
        max-height: 100%;
        margin: auto;
        border-radius: 4px;
        cursor: zoom-in;
      }
      /* Zoomed: show the image at its natural pixels and let the overlay scroll. */
      .lightbox.is-zoomed { justify-content: flex-start; align-items: flex-start; }
      .lightbox.is-zoomed img {
        max-width: none;
        max-height: none;
        cursor: zoom-out;
      }
      .lightbox-close {
        position: fixed;
        top: 1rem;
        right: 1rem;
        width: 2.4rem;
        height: 2.4rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--fg);
        background: color-mix(in srgb, var(--bg) 70%, transparent);
        border: 1px solid var(--rule);
        border-radius: 50%;
        cursor: pointer;
        line-height: 1;
      }
      .lightbox-close svg { width: 1.1rem; height: 1.1rem; display: block; }
    </style>

    <script>
      // Sun/moon theme toggle. The active theme lives on <html data-theme>, set
      // before paint by the inline head script. Clicking flips it and remembers
      // the choice; visitors who never choose keep following the OS preference.
      const themeToggle = document.getElementById('theme-toggle');
      themeToggle?.addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
        document.documentElement.dataset.theme = next;
        try { localStorage.setItem('theme', next); } catch {}
      });
      window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', (e) => {
        let saved = null;
        try { saved = localStorage.getItem('theme'); } catch {}
        if (saved !== 'light' && saved !== 'dark') {
          document.documentElement.dataset.theme = e.matches ? 'light' : 'dark';
        }
      });
    </script>

    <script>
      // Wrap every <pre> inside <main> with a div and append a Copy button.
      // Idempotent so re-runs (e.g. dev HMR) don't double up.
      const ICON_COPY = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
      const ICON_CHECK = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';

      document.querySelectorAll('main pre').forEach((pre) => {
        // Skip <pre> used as diagram art (e.g. the type-walk mapping); it is an
        // illustration, not copyable code, and the button would overlap it.
        if (pre.closest('figure.diagram')) return;
        if (pre.parentElement?.classList.contains('code-wrap')) return;
        if (pre.parentElement?.querySelector(':scope > .code-file-label .copy-btn')) return;

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'copy-btn';
        btn.setAttribute('aria-label', 'Copy code');
        btn.innerHTML = ICON_COPY;
        btn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText((pre as HTMLElement).innerText);
            btn.innerHTML = ICON_CHECK;
            btn.classList.add('is-copied');
          } catch {
            btn.setAttribute('aria-label', 'Copy failed');
          }
          setTimeout(() => {
            btn.innerHTML = ICON_COPY;
            btn.classList.remove('is-copied');
            btn.setAttribute('aria-label', 'Copy code');
          }, 1500);
        });

        const label = pre.parentElement?.querySelector(':scope > .code-file-label');
        if (label) {
          label.appendChild(btn);
        } else {
          const wrap = document.createElement('div');
          wrap.className = 'code-wrap';
          pre.parentNode?.insertBefore(wrap, pre);
          wrap.appendChild(pre);
          wrap.appendChild(btn);
        }
      });
    </script>

    <script>
      // Click-to-zoom lightbox for content images. Detailed screenshots render
      // small in the column, so clicking one opens it full-size in an overlay;
      // clicking the image again toggles actual-pixel zoom (the overlay scrolls),
      // and Escape or a click on the backdrop closes it. Images that are already
      // links keep their link behaviour and are left alone.
      const lightbox = document.createElement('div');
      lightbox.className = 'lightbox';
      lightbox.setAttribute('role', 'dialog');
      lightbox.setAttribute('aria-modal', 'true');
      lightbox.innerHTML =
        '<button type="button" class="lightbox-close" aria-label="Close">' +
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
        '</button><img alt="">';
      const lightboxImg = lightbox.querySelector('img') as HTMLImageElement;
      document.body.appendChild(lightbox);

      // Pick the highest-resolution candidate so the zoom shows real detail,
      // not the small variant the column happened to load.
      function bestSrc(img: HTMLImageElement): string {
        const set = img.getAttribute('srcset');
        if (set) {
          const best = set
            .split(',')
            .map((part) => {
              const [url, w] = part.trim().split(/\s+/);
              return { url, w: parseInt(w) || 0 };
            })
            .sort((a, b) => b.w - a.w)[0];
          if (best?.url) return best.url;
        }
        return img.currentSrc || img.src;
      }

      function closeLightbox() {
        lightbox.classList.remove('is-open', 'is-zoomed');
        lightboxImg.removeAttribute('src');
        document.body.style.overflow = '';
      }

      document.querySelectorAll<HTMLImageElement>('main img').forEach((img) => {
        if (img.closest('a')) return; // an intentional link, not a zoom target
        img.classList.add('zoomable');
        img.addEventListener('click', () => {
          lightboxImg.src = bestSrc(img);
          lightboxImg.alt = img.alt || '';
          lightbox.classList.remove('is-zoomed');
          lightbox.classList.add('is-open');
          document.body.style.overflow = 'hidden';
        });
      });

      lightbox.addEventListener('click', (e) => {
        // Clicking the image toggles zoom; clicking anywhere else closes.
        if (e.target === lightboxImg) lightbox.classList.toggle('is-zoomed');
        else closeLightbox();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && lightbox.classList.contains('is-open')) closeLightbox();
      });
    </script>
  </body>
</html>
