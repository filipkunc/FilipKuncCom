#!/bin/sh
# Pre-commit hook: validate ansible/files/Caddyfile when it is staged.
#
# Enable per clone: `npm run setup` (sets core.hooksPath to .githooks).

if ! git diff --cached --name-only | grep -q '^ansible/files/Caddyfile$'; then
  exit 0
fi

if ! command -v caddy >/dev/null 2>&1; then
  echo "pre-commit: caddy not installed, skipping Caddyfile validation."
  echo "  install on Fedora: sudo dnf install -y caddy"
  exit 0
fi

staged=$(mktemp)
trap 'rm -f "$staged"' EXIT
git show :ansible/files/Caddyfile > "$staged"

if ! output=$(ACME_EMAIL=x@example.com caddy validate --config "$staged" --adapter caddyfile 2>&1); then
  echo "$output" >&2
  echo "pre-commit: Caddyfile validation failed." >&2
  exit 1
fi

echo "pre-commit: Caddyfile valid."
