{
  "name": "filipkunc-com",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "filipkunc.com — Astro + MDX content site, served by a tiny Node static server.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "setup": "git config core.hooksPath .githooks",
    "dev": "astro dev",
    "build": "astro build && npm run build:server",
    "build:server": "tsc -p src/server/tsconfig.json",
    "start": "node server-dist/index.js",
    "preview": "astro preview",
    "verify": "node scripts/verify-snippets.mjs",
    "check": "astro check && tsc -p src/server/tsconfig.json --noEmit",
    "test:e2e": "playwright test",
    "bench": "node scripts/bench-normals.mjs",
    "bench:alloc": "node scripts/bench-allocators.mjs",
    "bench:codesearch": "node scripts/bench-codesearch.mjs"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/sitemap": "^3.7.2",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@webgpu/types": "^0.1.70",
    "astro": "^6.3.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@typescript/vfs": "^1.6.4",
    "katex": "^0.17.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  }
}
