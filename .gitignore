node_modules/
dist/
server-dist/

# Generated Open Graph images (npm run og, run as part of build). Derived from
# the post source images, so they are build artifacts, not tracked source.
/public/og/
/public/og-default.png
.astro/
.cache/
npm-debug.log*
.env
.env.local
*.local
.DS_Store
__pycache__/
*.pyc
.venv/
ansible/inventory.yml
ansible/.vault_pass

# Playwright
test-results/
playwright-report/
.playwright/

# Benchmark build artifacts (sources + results JSON are committed)
.tools/
bench/normals/mesh.bin
bench/normals/run-cuda
bench/normals/run-opencl
bench/normals/run-slang-host
bench/normals/run-slang.ptx

# Bazel convenience symlinks for the tcmalloc bench
bench/tcmalloc/bazel-*

# hb-editor: full fonts are fetched by build-wasm.sh; the wasm and the web
# font subsets ARE committed so the container build (git archive of the
# committed tree) is self-contained, same as the MeshMaker wasm in public/.
scripts/hb-editor/fonts/*.ttf
!scripts/hb-editor/fonts/*-subset.ttf
!scripts/hb-editor/dist/
!scripts/hb-editor/dist/hb-gpu.mjs
!scripts/hb-editor/dist/hb-gpu.wasm

# flowfield: cargo build dir is local-only; the wasm artifact IS committed
# (same rationale as hb-gpu.wasm above)
scripts/flowfield/target/
!scripts/flowfield/dist/
!scripts/flowfield/dist/flowfield.wasm
