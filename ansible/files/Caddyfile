# Caddy reverse proxy for filipkunc.com.
# The app container publishes on 127.0.0.1:8080 (rootless podman, host loopback).
# Caddy handles ACME (Let's Encrypt) automatically for the snippet's site name.
{
	email {$ACME_EMAIL}
}

# The www host gets its own certificate and a permanent redirect to the apex,
# so the site exists on exactly one canonical origin (search engines otherwise
# see duplicate content on both hosts).
www.filipkunc.com {
	redir https://filipkunc.com{uri} permanent
}

filipkunc.com {
	# Default encode whitelist skips application/octet-stream, but Emscripten
	# ships its asset bundles (.data files) under that MIME type and they are
	# very compressible. Override the match to add it.
	encode {
		zstd
		gzip
		match {
			header Content-Type text/*
			header Content-Type application/json*
			header Content-Type application/javascript*
			header Content-Type application/wasm*
			header Content-Type application/octet-stream*
			header Content-Type image/svg+xml*
		}
	}
	reverse_proxy 127.0.0.1:8080 {
		health_uri /healthz
		health_interval 10s
		health_timeout 2s
	}
}
