# Caddy reverse proxy for filipkunc.com.
# The app container publishes on 127.0.0.1:8080 (rootless podman, host loopback).
# Caddy handles ACME (Let's Encrypt) automatically for the snippet's site name.

{
    email {$ACME_EMAIL}
}

filipkunc.com, www.filipkunc.com {
    encode zstd gzip
    reverse_proxy 127.0.0.1:8080 {
        health_uri /healthz
        health_interval 10s
        health_timeout 2s
    }
}
